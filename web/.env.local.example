# Через Kong (как в корневом docker compose). Прямой доступ: dashboard :8080, projects :8081
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

NEXT_PUBLIC_PROJECTS_API_URL=http://localhost:8000
# NEXT_PUBLIC_PROJECTS_API_URL=http://localhost:8081

# NextAuth + Keycloak (см. docs/keycloak-setup.md)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
KEYCLOAK_CLIENT_ID=exponat-web
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=http://localhost:8090/realms/exponat-development
KEYCLOAK_API_CLIENT_ID=exponat-api
