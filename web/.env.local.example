# Публичный API: dashboard (напрямую к сервису) или через Kong на :8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Сервис projects (REST + WebSocket). Через Kong задайте тот же базовый URL, что и выше.
NEXT_PUBLIC_PROJECTS_API_URL=http://localhost:8081
# NEXT_PUBLIC_PROJECTS_API_URL=http://localhost:8000
