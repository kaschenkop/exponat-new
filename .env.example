# Database
DATABASE_URL=postgresql://user:password@localhost:5432/exponat_dev
REDIS_URL=redis://localhost:6379

# API (через Kong: http://localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8080
API_SECRET_KEY=your-secret-key

# Auth (Next.js + Keycloak)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
KEYCLOAK_CLIENT_ID=exponat-web
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=http://localhost:8090/realms/exponat-development
KEYCLOAK_API_CLIENT_ID=exponat-api

# OIDC / projects service (JWT RS256 via JWKS)
# OIDC_ISSUER=http://localhost:8090/realms/exponat-development
# JWT_JWKS_URL=http://localhost:8090/realms/exponat-development/protocol/openid-connect/certs

# OAuth (legacy / другие интеграции)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# 1C Integration
ONEC_API_URL=http://localhost:8081/api
ONEC_USERNAME=
ONEC_PASSWORD=

# AI/LLM
OPENAI_API_KEY=
YANDEXGPT_API_KEY=

# File Storage
S3_BUCKET=exponat-uploads
S3_REGION=ru-central1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Monitoring
SENTRY_DSN=
